#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
. "${plugin_dir}/lib/utils.bash"

# Use the GitHub releases/latest redirect to find the latest stable version.
# curl -sI follows the redirect and we extract the version from the Location header.
local_curl_opts=(-sI)

if [ -n "${GITHUB_API_TOKEN:-}" ]; then
	local_curl_opts=("${local_curl_opts[@]}" -H "Authorization: token $GITHUB_API_TOKEN")
fi

redirect_url=$(curl "${local_curl_opts[@]}" "$GH_REPO/releases/latest" | sed -n -e "s|^[Ll]ocation: *||p" | sed -n -e "s|\r||p")

version=
if [[ -n "$redirect_url" && "$redirect_url" != "$GH_REPO/releases" ]]; then
	version="$(printf "%s\n" "$redirect_url" | sed 's|.*/tag/v\{0,1\}||')"
fi

# Fallback: if we couldn't resolve from the redirect, use list-all
if [[ -z "$version" ]]; then
	version="$(list_all_versions | sort_versions | tail -n1 | xargs echo)"
fi

printf "%s\n" "$version"
